---
const appStoreUrl = '#'; // TODO: real App Store URL
const playStoreUrl = '#'; // TODO: real Google Play URL
---

<div class="store-badges">
  <a
    class="store-badge store-badge--apple"
    href={appStoreUrl}
    aria-label="Download Arcticalm on the App Store"
    rel="noopener"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="currentColor"
        d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
      />
    </svg>
    <span class="store-badge__text">
      <span class="store-badge__small">Download on the</span>
      <span class="store-badge__large">App Store</span>
    </span>
  </a>

  <a
    class="store-badge store-badge--google"
    href={playStoreUrl}
    aria-label="Get Arcticalm on Google Play"
    rel="noopener"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path fill="#EA4335" d="M3.6 1.7c-.3.3-.5.8-.5 1.4v17.8c0 .6.2 1.1.5 1.4l11-11-11-9.6z" />
      <path fill="#FBBC04" d="M18.2 14.5l-3.6-3.4-3 3 3 3 3.6-2.1c1.1-.6 1.1-1.9 0-2.5z" />
      <path fill="#4285F4" d="M14.6 11.1l-3 3 3 3.4 4-2.3-4-4.1z" />
      <path fill="#34A853" d="M3.6 22.3c.4.4 1 .5 1.7.1l13.5-7.7-4.2-3.6-11 11.2z" />
      <path fill="#34A853" opacity=".0" d="M0 0h24v24H0z" />
    </svg>
    <span class="store-badge__text">
      <span class="store-badge__small">GET IT ON</span>
      <span class="store-badge__large">Google Play</span>
    </span>
  </a>
</div>

<style>
  .store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.1rem;
    border-radius: 0.6rem;
    background: #0a0a0a;
    color: #fff;
    text-decoration: none;
    min-height: 56px;
    min-width: 180px;
    transition: transform 120ms ease, background 120ms ease;
  }

  .store-badge:hover,
  .store-badge:focus-visible {
    transform: translateY(-1px);
    background: #1a1a1a;
  }

  .store-badge:focus-visible {
    outline: 3px solid #2c5b87;
    outline-offset: 2px;
  }

  .store-badge svg {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
  }

  .store-badge__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-align: left;
  }

  .store-badge__small {
    font-size: 0.7rem;
    opacity: 0.85;
  }

  .store-badge__large {
    font-size: 1.05rem;
    font-weight: 600;
  }
</style>
